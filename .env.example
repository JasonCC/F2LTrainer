# Public client environment variables (exposed to the browser).
#
# Copy this file to `.env` and fill in real values to enable cloud sync and
# sign-in. The app is offline-first and runs WITHOUT these — sync and auth are
# simply disabled when they are missing.
#
# Vite only reads .env at startup, so restart `pnpm run dev` after editing it.

# Convex deployment URL — printed by `npx convex dev`.
PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# Clerk publishable key (starts with pk_test_ or pk_live_) — from the Clerk
# dashboard at https://dashboard.clerk.com/
PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
